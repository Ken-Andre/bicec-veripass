# =============================================================================
# BICEC VeriPass — Variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs
# NE JAMAIS committer .env dans git
# =============================================================================

# ── Environnement ──────────────────────────────────────────────────────────
ENV=development          # development | production
DEBUG=true

# ── Base de données PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=veripass
POSTGRES_USER=veripass_user
POSTGRES_PASSWORD=changeme_strong_password

# URL complète (utilisée par SQLAlchemy / Alembic)
DATABASE_URL=postgresql+asyncpg://veripass_user:changeme_strong_password@postgres:5432/veripass

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme_256bit_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8       # Back-office
JWT_CLIENT_TOKEN_EXPIRE_HOURS=24      # PWA Marie

# ── Chiffrement AES-256 (biométrie, GPS) ───────────────────────────────────
AES_SECRET_KEY=changeme_32bytes_aes_key_here_base64

# ── Orange Cameroon SMS API ────────────────────────────────────────────────
OTP_MODE=dev_local               # dev_local | orange  (dev_local interdit en prod)
ORANGE_APP_ID=pMTnm7GeS9AxgrR4
ORANGE_CLIENT_ID=changeme
ORANGE_CLIENT_SECRET=changeme
ORANGE_BASE_URL=https://api.orange.com/smsmessaging/v1

# ── Email (reset mot de passe Admin IT) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@bicec.cm
SMTP_PASSWORD=changeme
SMTP_FROM=VeriPass <noreply@bicec.cm>

# ── Celery ─────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Modèles AI (chemins dans le container) ─────────────────────────────────
PADDLE_OCR_MODEL_DIR=/data/models/paddleocr
GLM_OCR_MODEL_DIR=/data/models/glm-ocr
MINIFASNET_MODEL_PATH=/data/models/minifasnet/anti_spoof.onnx
DEEPFACE_MODEL_DIR=/data/models/deepface

# ── Stockage fichiers ──────────────────────────────────────────────────────
DOCUMENTS_BASE_PATH=/data/documents
MAX_UPLOAD_SIZE_MB=10

# ── Seuils OCR ─────────────────────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=85          # % — en dessous → fallback GLM-OCR
OCR_PADDLE_TIMEOUT_S=5
OCR_GLM_TIMEOUT_S=30

# ── Seuils biométrie ───────────────────────────────────────────────────────
LIVENESS_MIN_SCORE=70                # % — en dessous → strike
FACE_MATCH_MIN_SCORE=80              # % — en dessous → rejet
LIVENESS_MAX_STRIKES=3

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://localhost:3000,https://localhost:3001

# ── Admin IT seed ──────────────────────────────────────────────────────────
ADMIN_IT_SEED_EMAIL=admin@bicec.cm
ADMIN_IT_SEED_PASSWORD=changeme_first_login_password
