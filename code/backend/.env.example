# ============================================================
# BICEC VeriPass — .env.example (Template partagé)
# ============================================================
# Copiez ce fichier en .env et adaptez les valeurs

# --- Base de données -----------------------------------------
# LOCAL  : postgresql+asyncpg://postgres:postgres@localhost:5432/veripass
# DOCKER : postgresql+asyncpg://vp_user:${DB_PASSWORD}@postgres:5432/veripass
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/veripass

# --- Redis ---------------------------------------------------
# LOCAL  : redis://localhost:6379/0  (ou fakeredis via les tests)
# DOCKER : redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# --- Sécurité ------------------------------------------------
JWT_SECRET=CHANGEME_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Application ---------------------------------------------
ENVIRONMENT=development
DEBUG=false

# --- CORS ----------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- Stockage ------------------------------------------------
STORAGE_PATH=./data/storage

# --- OCR (seuil conforme architecture §12) ------------------
OCR_CONFIDENCE_THRESHOLD=0.85
PADDLE_LAZY_LOAD=true
